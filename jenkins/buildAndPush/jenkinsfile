pipeline{

    agent{
        label 'docker'
    }

    environment{
        IMAGE_NAME="sdasa/restatestng:${env.BUILD_ID}"
    }

    stages{
        stage('Maven Compile Project'){
            steps{
                sh 'mvn clean verify -DskipTests'
            }
        }

        stage('Docker build Image'){
            steps{
                script{
                    image=docker.build("${IMAGE_NAME}", "-f ./cn/Dockerfile --no-cache .")
                }
            }
        }

        stage('Push Docker Image'){
            steps{
                script{
                    docker.withDockerRegistry('', 'DockerHubPersonalToken2')
                    image.push()
                }
            }
        }
    }
}